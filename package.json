{
  "name": "txma-audit",
  "version": "1.0.14",
  "type": "module",
  "description": "TxMA Audit",
  "repository": {
    "type": "git",
    "repository": "https://github.com/govuk-one-login/txma-audit"
  },
  "author": "GDS",
  "license": "MIT",
  "engines": {
    "node": "^24.0.0"
  },
  "scripts": {
    "build": "tsc --noEmit && tsx ./esbuild.config.ts",
    "deploy:dev": "npm run build && sam deploy --resolve-s3",
    "lint": "prettier . --check || exit 1 ; eslint . --max-warnings=0",
    "lint:fix": "prettier . --write ; eslint . --fix",
    "postinstall": "husky",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "test:integration": "vitest run -c ./tests/integrationTests/vitest.config.integration.ts",
    "test:e2e": "vitest run -c ./tests/e2eTests/vitest.config.e2e.ts",
    "tsFile": "tsx"
  },
  "dependencies": {
    "@aws-crypto/client-node": "5.0.0",
    "@aws-crypto/decrypt-node": "5.0.0",
    "@aws-crypto/encrypt-node": "5.0.0",
    "@aws-crypto/material-management": "5.0.0",
    "@aws-lambda-powertools/logger": "2.34.0",
    "@aws-sdk/client-firehose": "3.1092.0",
    "@aws-sdk/client-s3": "3.1092.0",
    "@aws-sdk/client-s3-control": "3.1092.0",
    "aws-xray-sdk-core": "3.12.0"
  },
  "resolutions": {
    "micromatch": "4.0.8"
  },
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "^3.1092.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1092.0",
    "@aws-sdk/client-lambda": "^3.1092.0",
    "@aws-sdk/client-secrets-manager": "^3.1092.0",
    "@aws-sdk/client-ssm": "^3.1092.0",
    "@aws-sdk/client-sso-oidc": "^3.1092.0",
    "@aws-sdk/client-sts": "^3.1092.0",
    "@aws-sdk/util-endpoints": "3.996.33",
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "8.10.162",
    "@types/node": "26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "1.6.23",
    "aws-sdk-client-mock": "4.1.0",
    "commander": "15.0.0",
    "esbuild": "0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "^17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.1.1",
    "prettier": "3.9.6",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.0.18",
    "vitest-when": "^0.10.0",
    "yaml-cfn": "0.3.2"
  },
  "lint-staged": {
    "*": "prettier --write .",
    "*.{js,ts}": "eslint --fix ."
  },
  "overrides": {
    "fast-xml-parser": "5.4.1"
  }
}
